      * {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
  background-color: #fdfbf6; /* Light brownish white */
  color: #2b3e2b; /* Dark green */
  line-height: 1.6;
  padding: 20px 40px;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

header {
  border-bottom: 2px solid #8d6e63; /* Light brown */
  margin-bottom: 24px;
  padding-bottom: 8px;
}

.title {
  font-weight: 900;
  font-size: 2.5rem;
  color: #2e7d32; /* Medium green */
  margin-bottom: 8px;
}

nav {
  display: flex;
  gap: 24px;
}

nav a {
  text-decoration: none;
  color: #558b2f;
  font-weight: 600;
  padding: 6px 10px;
  border-radius: 4px;
  transition: background-color 0.25s ease;
}

nav a:hover,
nav a.active {
  background-color: #a5d6a7;
  color: #1b5e20;
}

main {
  flex-grow: 1;
  max-width: 900px;
  margin: 0 auto;
}

h2 {
  color: #558b2f;
  margin-bottom: 15px;
  border-bottom: 2px solid #8d6e63;
  padding-bottom: 4px;
}

h3 {
  color: #3e6d3e;
  margin-top: 1.2rem;
  margin-bottom: 8px;
}

ul, ol { margin-left: 26px; 
      margin-bottom: 2 rem; 
      list-style-position: inside; 
}

.steps li {
  margin-bottom: 28px;
  border-left: 4px solid #4caf50;
  padding-left: 14px;
  background: #e6f2d6;
  border-radius: 6px;
}

.steps img {
  width: 100%;
  max-width: 300px;
  border-radius: 8px;
  margin: 10px 0;
  box-shadow: 0 3px 6px #c8d5b7;
}

.feedback {
  list-style-type: disc;
  margin-left: 25px;
  font-style: italic;
  color: #2f4f2f;
}

footer {
  text-align: center;
  padding: 16px 0;
  border-top: 2px solid #8d6e63;
  color: #7f7f7f;
  font-size: 0.9rem;
  margin-top: 40px;
}
